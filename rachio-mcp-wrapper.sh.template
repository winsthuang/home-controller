#!/bin/bash

# Suppress dotenv v17 startup banner from polluting stdout (MCP needs clean JSON on stdout)
export DOTENV_CONFIG_QUIET=true
# Wrapper script for Rachio Sprinkler Controller MCP server
# Loads environment variables from .env before starting the server

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

if [ -f "$SCRIPT_DIR/.env" ]; then
  export $(grep -v '^#' "$SCRIPT_DIR/.env" | xargs)
fi

exec node "$SCRIPT_DIR/rachio-mcp-server.js"
